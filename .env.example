# ═══════════════════════════════════════════════════════════
# P2P Arbitrage Scout — Environment Variables Template
# Copy this file to .env (local dev) or set in Vercel (production)
# ═══════════════════════════════════════════════════════════

# ── DATABASE (Neon Postgres — works for BOTH dev and prod) ─
# Create a FREE Neon project at https://neon.tech
# Use the POOLER connection for DATABASE_URL (serverless-safe)
# Use the DIRECT connection for DIRECT_URL (migrations only)
#
# IMPORTANT: Both dev and prod use Postgres (schema.prisma provider = "postgresql")
# SQLite is NO LONGER supported (Vercel serverless filesystem is read-only)

DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── LLM (OpenRouter — 10 free models in rotation) ─────────
# Get a FREE key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── TELEGRAM BOT ──────────────────────────────────────────
# Create bot via @BotFather, get token
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"

# Channel IDs (negative, start with -100) — get via @userinfobot or curl getChat
TELEGRAM_CHANNEL_FR_ID="-1001234567890"
TELEGRAM_CHANNEL_EN_ID="-1001234567891"

# ── SECURITY (optional but recommended) ───────────────────
# Random 32-char string to protect /api/scan/trigger endpoint
# If set, external crons must send ?key=CRON_API_KEY (GET) or X-API-Key header (POST)
CRON_API_KEY="genere-une-cle-aleatoire-32-caracteres"

# Your personal Telegram ID (for admin alerts) — get via @userinfobot
ADMIN_TELEGRAM_ID="987654321"

# ── UPSTASH QSTASH (optional — for cron bypass Method D) ──
QSTASH_TOKEN="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
